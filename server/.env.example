# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+psycopg2://sharedlinks_user:sharedlinks_pass@localhost:5432/sharedlinks_db
SQL_ECHO=false

# ---- CORS ----
# The client is a Vite app (npm run dev -> http://localhost:5173 by default)
CORS_ORIGINS=http://localhost:5173

# ---- Shared link URLs ----
PUBLIC_BASE_URL=https://localhost/share

# ---- File storage ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ---- Email (FastAPI-Mail) ----
MAIL_ENABLED=false
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=no-reply@trustshare.example.com
MAIL_FROM_NAME=TrustShare
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ---- Background scheduler ----
SCHEDULER_ENABLED=true
EXPIRATION_CHECK_INTERVAL_MINUTES=60
EXPIRY_WARNING_HOURS=24

LOG_LEVEL=INFO

