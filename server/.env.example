# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+psycopg2://sharedlinks_user:sharedlinks_pass@localhost:5432/sharedlinks_db
SQL_ECHO=false

# ---- CORS ----
# The client is a Vite app (npm run dev -> http://localhost:5173 by default)
CORS_ORIGINS=http://localhost:5173

# ---- Shared link URLs ----
PUBLIC_BASE_URL=https://localhost/share

# ---- File storage (My Files module) ----
# Local disk today; swap src/files/storage.py's backend to migrate to S3/Azure.
FILES_STORAGE_DIR=./storage/files
MAX_UPLOAD_SIZE_MB=200
# Comma-separated, no dots, lowercase. Leave unset to use the built-in default list.
# ALLOWED_FILE_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,csv,md,jpg,jpeg,png,gif,zip

# Real AES-256-GCM at-rest encryption key (urlsafe-base64, must decode to 32 bytes).
# Generate one with:
#   python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# REQUIRED before any file upload will work - there is no insecure default.
FILES_ENCRYPTION_KEY=

# Default per-user storage quota, applied when a user row is created.
DEFAULT_STORAGE_QUOTA_GB=500

# How long a file stays in Trash before it's permanently purged.
TRASH_RETENTION_DAYS=30
TRASH_PURGE_INTERVAL_HOURS=24

# ---- Email (FastAPI-Mail) ----
MAIL_ENABLED=false
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=no-reply@trustshare.example.com
MAIL_FROM_NAME=TrustShare
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ---- Background scheduler ----
SCHEDULER_ENABLED=true
EXPIRATION_CHECK_INTERVAL_MINUTES=60
EXPIRY_WARNING_HOURS=24

LOG_LEVEL=INFO

