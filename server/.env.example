# PostgreSQL connection
DATABASE_URL=postgresql+psycopg2://trustshare_user:trustshare_pass@localhost:5432/trustshare

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Short-lived token issued right after password check, exchanged for a full
# access token once MFA is verified (only relevant for users with MFA enabled)
MFA_TOKEN_EXPIRE_MINUTES=5

# App
APP_NAME=TrustShare
ENVIRONMENT=development

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
