# Copy this file to `.env` and adjust as needed.

# ── PostgreSQL connection ────────────────────────────────────────────────
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://secureShare:scureShare@localhost:5432/secureShare

# ── Auth / JWT ───────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── App URLs (used by OAuth redirects) ───────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── OAuth / social login ─────────────────────────────────────────────────
# Register an app with each provider and paste the credentials below.
# Set each provider's Authorization callback / redirect URI to:
#   {BACKEND_URL}/api/auth/oauth/<provider>/callback
# e.g. http://localhost:8000/api/auth/oauth/google/callback
#
# Google   -> https://console.cloud.google.com/apis/credentials  (OAuth client ID, type "Web application")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft -> https://portal.azure.com  (Azure AD -> App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# GitHub   -> https://github.com/settings/developers  (OAuth Apps -> New OAuth App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
