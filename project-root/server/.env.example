# Local runtime
ENVIRONMENT=development
DATABASE_URL=sqlite:///./app.db
SECRET_KEY=replace-with-a-long-random-value
MASTER_KEY=replace-with-a-different-long-random-value
DATA_DIR=.

# Public URLs and CORS
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/oauth/microsoft/callback
