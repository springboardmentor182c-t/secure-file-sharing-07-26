# Local runtime
ENVIRONMENT=development
DATABASE_URL=sqlite:///./app.db
COMPOSE_DATABASE_URL=postgresql://trustshare:trustshare-local-only@database:5432/trustshare
SECRET_KEY=replace-with-a-long-random-value
MASTER_KEY=replace-with-a-different-long-random-value
DATA_DIR=.

# Public URLs and CORS (required; set environment-specific values in .env)
FRONTEND_URL=
BACKEND_URL=
BACKEND_CORS_ORIGINS=
REACT_APP_API_URL=

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=  # Optional; defaults to BACKEND_URL plus the callback path.

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=  # Optional; defaults to BACKEND_URL plus the callback path.
