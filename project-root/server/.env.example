# ── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=trustshare-super-secret-key-change-in-prod-2026

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail: Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
# Create an App Password for "Mail" and paste it as SMTP_PASSWORD below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=you@gmail.com

# ── Frontend URL (used in password reset links) ───────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: http://localhost:8000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Microsoft OAuth2 ──────────────────────────────────────────────────────────
# portal.azure.com → App Registrations → your app → Certificates & secrets
# Redirect URI: http://localhost:8000/api/auth/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
